# Copia este archivo como ".env" y completa los valores reales
# NUNCA subas el archivo ".env" al repositorio — ya está en .gitignore

# MongoDB Atlas connection string
# Formato: mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<nombre_bd>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/market_mascotas?retryWrites=true&w=majority

# Puerto del servidor (Render lo asigna automáticamente en producción)
PORT=5000

# Secret para firmar JWT — usa una cadena larga y aleatoria en producción
JWT_SECRET=cambia_esto_por_un_string_largo_y_secreto